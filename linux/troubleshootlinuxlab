#!/bin/bash
# troubleshootlinuxlab - Main training lab CLI for Docker Desktop on Linux
#
# Usage:
#   troubleshootlinuxlab              # Interactive lab selection menu
#   troubleshootlinuxlab --check      # Grade your current lab
#   troubleshootlinuxlab --status     # Show active lab
#   troubleshootlinuxlab --report     # Show your report card
#   troubleshootlinuxlab --abandon    # Abandon the active lab
#   troubleshootlinuxlab --reset      # Re-break the current lab to try again
#   troubleshootlinuxlab --help       # Show help
#
# Architecture overview
# ---------------------
# This script is the single entry point trainees interact with. Everything
# else is support infrastructure:
#
#   lib/colors.sh    - Color variables (RED, GREEN, YELLOW, BLUE, NC)
#   lib/state.sh     - Read/write ~/.docker-training-labs/config.json via python3
#   lib/grading.sh   - Append rows to ~/.docker-training-labs/grades.csv
#
#   scenarios/break_<n>.sh  - Deliberately corrupt Docker Desktop
#   scenarios/all.sh        - Trainer-only restore script (not for trainees)
#   tests/test_<n>.sh       - Verify the scenario has been fixed
#
# Lab lifecycle
# -------------
#   1. Trainee selects a lab; start_lab runs scenarios/break_<n>.sh and
#      records the scenario name and start time in config.json
#   2. Trainee diagnoses and fixes Docker Desktop manually
#   3. --check runs tests/test_<n>.sh, parses the structured footer,
#      records the grade, and prints feedback
#   4. config.json is cleared so a new lab can be started
#
# Output contract (tests/test_*.sh footer, parsed by check_lab)
# -------------------------------------------------------------
#   Score: <n>%
#   Tests Passed: <n>    <- written by generate_report in test_framework.sh
#   Tests Failed: <n>    <- written by generate_report in test_framework.sh
#
# Scenario name convention
# ------------------------
#   Lab names (DNS, PORT, PROXY, SSO, BRIDGE, AUTHCONFIG, PROXYFAIL) are
#   stored verbatim in config.json and lowercased at runtime to derive
#   filenames: break_dns.sh / test_dns.sh, break_ports.sh / test_port.sh, etc.
#
# Difference from Mac/Windows versions
# -------------------------------------
#   lib/state.sh uses python3 for JSON reads and writes (vs. sed on Mac,
#   ConvertFrom-Json on Windows). This is safe on Linux because python3 is
#   a stated prerequisite checked by install.sh.

# set -e is intentionally omitted. This is an interactive script with a menu
# loop and functions that legitimately return non-zero (e.g. user cancels a
# prompt). Errors are handled explicitly at each call site instead.

# ------------------------------------------------------------------
# Configuration
# ------------------------------------------------------------------
INSTALL_DIR="/usr/local/lib/docker-training-labs"
STATE_DIR="$HOME/.docker-training-labs"
CONFIG_FILE="$STATE_DIR/config.json"
GRADES_FILE="$STATE_DIR/grades.csv"
REPORTS_DIR="$STATE_DIR/reports"

# Ensure runtime state directories exist (safe to run on every invocation)
mkdir -p "$STATE_DIR" "$REPORTS_DIR" 2>/dev/null || true

# Bootstrap config file if it was removed or never created
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" << EOF
{
  "version": "1.0.0",
  "trainee_id": "$USER",
  "current_scenario": null,
  "scenario_start_time": null
}
EOF
fi

# Bootstrap grades file if missing
if [ ! -f "$GRADES_FILE" ]; then
    echo "trainee_id,scenario,score,timestamp,duration_seconds" > "$GRADES_FILE"
fi

# Source shared library functions
source "$INSTALL_DIR/lib/colors.sh"
source "$INSTALL_DIR/lib/state.sh"
source "$INSTALL_DIR/lib/grading.sh"

# ------------------------------------------------------------------
# show_banner
# ------------------------------------------------------------------
show_banner() {
    clear
    echo -e "${BLUE}=========================================="
    echo "Docker Desktop Training Labs"
    echo "Break-Fix Troubleshooting Practice"
    echo -e "==========================================${NC}"
    echo ""
}

# ------------------------------------------------------------------
# show_main_menu
# ------------------------------------------------------------------
show_main_menu() {
    show_banner

    local current_scenario
    current_scenario=$(get_current_scenario)

    if [ -n "$current_scenario" ] && [ "$current_scenario" != "null" ]; then
        # An active lab is in progress - offer continuation options
        echo -e "${YELLOW}WARNING: You currently have an active lab: $current_scenario${NC}"
        echo ""
        echo "1. Continue working on current lab"
        echo "2. Submit current lab for grading"
        echo "3. Abandon current lab and start new (requires manual Docker Desktop restart)"
        echo "4. View my report card"
        echo "0. Exit"
    else
        # No active lab - show the full lab selection menu
        echo "Select a training lab:"
        echo ""
        echo "1. Container Connections"
        echo ""
        echo "2. Port Problems"
        echo ""
        echo "3. Pull Problems"
        echo ""
        echo "4. Login Problems"
        echo ""
        echo "5. Broken Networking"
        echo ""
        echo "6. Auth Config Errors"
        echo ""
        echo "7. Proxy Connection Issues"
        echo ""
        echo "8. View my report card"
        echo ""
        echo "0. Exit"
    fi

    echo ""
    echo -e "${BLUE}==========================================${NC}"
}

# ------------------------------------------------------------------
# show_lab_instructions - Print the brief for the named lab
#
# Adding a new lab requires: a break_<lower>.sh, a test_<lower>.sh,
# a new case here, a new case in start_lab, and a menu entry in
# show_main_menu.
# ------------------------------------------------------------------
show_lab_instructions() {
    local lab=$1

    case $lab in
        DNS)
            cat << 'EOF'
Problem: docker pull fails with a DNS write error

The Docker daemon cannot resolve external hostnames. Image pulls
fail immediately with an error like:

  write udp ...: write: operation not permitted

Your Linux host DNS works fine. Interestingly, nslookup inside a
container may also appear to work. The daemon and containers
use different DNS paths - that discrepancy is your first clue.

Symptoms you should observe:
  - docker pull fails with "write: operation not permitted"
  - Error references a DNS lookup on an internal IP (e.g. 192.168.65.x)
  - Host machine DNS works fine
  - docker run --rm alpine:latest nslookup google.com may succeed

Diagnostic Commands to Try:
  docker pull hello-world
  docker info | grep -i dns
  cat ~/.docker/daemon.json
  docker run --rm alpine:latest nslookup google.com

If config looks clean, think about what sits between the daemon
and the network. Check whether traffic is being blocked at a
lower level inside the Docker VM:

  docker run --rm --privileged --pid=host alpine:latest \
    nsenter -t 1 -m -u -n -i sh -c 'iptables -L OUTPUT -n -v'

Restarting Docker Desktop will clear the problem as a last
resort, but try to find and remove the root cause first.
EOF
            ;;
        PORT)
            cat << 'EOF'
Problem: Containers fail to bind to common ports

When you try to start containers that need standard ports
(80, 443, 3306, 5432, 8080), you get "address already in use"
errors.

Symptoms you should observe:
  - docker run -p 80:80 nginx:alpine fails with port allocation error
  - Multiple ports are mysteriously occupied
  - Some blocking containers may be hard to find

Diagnostic Commands to Try:
  docker ps -a
  sudo lsof -nP -iTCP:80 | grep LISTEN
  docker ps -a --filter "name=."
  netstat -tlnp | grep LISTEN

Note: not all port conflicts come from Docker containers.
Check lsof output carefully - some may be host processes.

Fix it by identifying and removing port conflicts!
EOF
            ;;
        PROXY)
            cat << 'EOF'
Problem: Docker cannot reach external registries

Your Docker cannot pull images or access external resources.
This is likely due to proxy misconfiguration.

Symptoms you should observe:
  - docker pull fails with a proxy connection error
  - Containers can't reach the internet
  - Host machine internet access works fine

On Linux, proxy config lives in two places:

  Layer 1: Daemon config (requires Docker restart after editing)

    Docker Desktop for Linux:  ~/.docker/daemon.json
    Docker Engine (plain):     /etc/docker/daemon.json  (needs sudo)

    These are NOT interchangeable. Docker Desktop ignores
    /etc/docker/daemon.json, and Docker Engine ignores
    ~/.docker/daemon.json. Writing the wrong file has no effect.

    To identify which flavor you have:
      docker info --format '{{.OperatingSystem}}'
      (returns "Docker Desktop" or your Linux distro name)

  Layer 2: Shell environment variables
    ~/.bashrc  or  ~/.bash_profile

    NOTE: Shell env vars affect only the Docker CLI - NOT the
    daemon. The daemon runs as a systemd service with its own
    isolated environment. Fixing only the shell RC will not
    resolve docker pull failures.

Diagnostic Commands to Try:
  docker pull hello-world
  docker info | grep -i proxy
  docker info --format '{{.OperatingSystem}}'
  cat ~/.docker/daemon.json          # Docker Desktop path
  sudo cat /etc/docker/daemon.json   # Docker Engine path
  env | grep -i proxy

Look for:
  - Invalid proxy hostnames or unroutable addresses in daemon.json
  - HTTP_PROXY / HTTPS_PROXY set in your shell environment

Fix both layers to fully resolve the issue!
EOF
            ;;
        SSO)
            cat << 'EOF'
Problem: Docker Desktop keeps signing you out immediately

After starting Docker Desktop, you find yourself signed out.
When you try to sign back in - via SSO or plain docker login -
the auth flow completes successfully, but Docker Desktop
immediately reverts to a signed-out state. Every attempt loops.

Symptoms you should observe:
  - Docker Desktop shows you as signed out
  - docker info shows no Username field
  - docker pull still works for public images
  - Auth appears to complete but nothing sticks

The fact that pulls still work tells you the Docker daemon is
healthy and network connectivity is fine. Something is
preventing credentials from being saved after a successful login.

Diagnostic Commands to Try:
  docker info | grep -i username
  docker pull alpine:latest
  cat ~/.docker/config.json
  docker login

Look for:
  - A "credsStore" key in ~/.docker/config.json
  - Its value: should be a credential helper binary that actually
    exists on your system (e.g. "desktop" requires the binary
    docker-credential-desktop to be in your PATH)
  - Run: which docker-credential-<value> to verify it exists

If the binary doesn't exist, Docker cannot save the token after
auth completes - hence the loop. Fix the credsStore value (or
remove the key entirely to use Docker's default), sign back in,
then run troubleshootlinuxlab --check.
EOF
            ;;
        BRIDGE)
            cat << 'EOF'
Problem: Container networking is broken

Your containers start successfully but have no network
connectivity. They can't reach the internet or each other,
even though they appear to have IP addresses.

Symptoms you should observe:
  - Containers can't ping external IPs
  - Containers can't communicate with each other
  - Docker daemon is running normally
  - Network appears to exist but doesn't work

Diagnostic Commands to Try:
  docker network ls
  docker network inspect bridge
  docker run --rm alpine:latest ping -c 3 8.8.8.8
  docker run --rm alpine:latest ip route

The blocking rule lives inside the Docker Desktop VM, not on
the Linux host directly. To inspect it, you need to use a
privileged container to enter the VM's network namespace:

  docker run --rm --privileged --pid=host alpine:latest \
    nsenter -t 1 -m -u -n -i sh -c 'iptables -L FORWARD -n -v'

Look for DROP rules targeting docker0. Fix it by removing the
offending iptables rule and cleaning up the test containers.
EOF
            ;;
        AUTHCONFIG)
            cat << 'EOF'
Problem: Docker Desktop keeps signing you out immediately

After restarting Docker Desktop, you find yourself signed out.
When you attempt to sign in via SSO, the browser auth completes
successfully - but Docker Desktop immediately signs you out again.
This happens every single time, with no error message explaining why.

Unlike the SSO lab, the proxy configuration is clean. Something
else in Docker Desktop's settings is causing every authenticated
session to be rejected the moment it is established.

Symptoms you should observe:
  - Docker Desktop shows you as signed out on startup
  - docker info shows no Username field
  - SSO loop: browser completes but Desktop immediately logs out
  - docker pull still works for public images (daemon is healthy)
  - No proxy errors in Docker Desktop logs

The fact that the daemon runs fine and pulls work rules out a
proxy or network problem. The issue is in how Docker Desktop is
configured to validate who is allowed to be signed in.

Diagnostic Commands to Try:
  docker info | grep -i username
  docker pull alpine:latest
  cat ~/.docker/desktop/settings.json

Look for:
  - The allowedOrgs key in settings.json
  - Its value format: should be a plain org slug like ["my-company"]
    not a URL like ["https://hub.docker.com/u/my-company"]

Fix the allowedOrgs value, restart Docker Desktop, sign back in,
then run troubleshootlinuxlab --check.
EOF
            ;;
        PROXYFAIL)
            cat << 'EOF'
Problem: Docker cannot reach external registries

Your Docker Desktop cannot pull images. Attempts fail immediately
with a connection error - there is no timeout, the failure is
instant. Container internet access is also broken.

This is a proxy misconfiguration, but the error behaviour is
different from a misconfigured proxy that simply doesn't route
traffic. Pay attention to whether the error says "connection
refused" or "connection timed out" - that distinction tells you
exactly what kind of proxy problem you're dealing with.

On Linux, Docker Desktop proxy config lives in:
  ~/.docker/desktop/settings.json  (preferred)
  ~/.docker/daemon.json            (fallback)

Symptoms you should observe:
  - docker pull fails immediately (no long wait before error)
  - Error message includes "connection refused"
  - Containers can't reach the internet
  - Host machine internet access works fine
  - No bogus proxy variables in shell environment (env | grep -i proxy)

Diagnostic Commands to Try:
  docker pull hello-world
  docker info | grep -i proxy
  cat ~/.docker/desktop/settings.json
  cat ~/.docker/daemon.json
  env | grep -i proxy

Look for:
  - ProxyHTTPMode set to "manual"
  - ProxyHTTP / ProxyHTTPS pointing to a loopback address (127.0.0.1)
    with a port that has nothing listening on it

Fix the proxy config and restart Docker Desktop to resolve!
EOF
            ;;
    esac
}

# ------------------------------------------------------------------
# start_lab - Run the break script and record state
#
# lab_name is the canonical scenario identifier. It is stored in
# config.json and lowercased at runtime to derive both the break
# script and test script filenames. Adding a new lab requires: a
# break_<lower>.sh, a test_<lower>.sh, a new case here, and menu
# entries in show_main_menu.
# ------------------------------------------------------------------
start_lab() {
    local lab_number=$1
    local lab_name=""
    local break_script=""

    case $lab_number in
        1)
            lab_name="DNS"        # -> scenarios/break_dns.sh, tests/test_dns.sh
            break_script="$INSTALL_DIR/scenarios/break_dns.sh"
            ;;
        2)
            lab_name="PORT"       # -> scenarios/break_ports.sh, tests/test_port.sh
            break_script="$INSTALL_DIR/scenarios/break_ports.sh"
            ;;
        3)
            lab_name="PROXY"      # -> scenarios/break_proxy.sh, tests/test_proxy.sh
            break_script="$INSTALL_DIR/scenarios/break_proxy.sh"
            ;;
        4)
            lab_name="SSO"        # -> scenarios/break_sso.sh, tests/test_sso.sh
            break_script="$INSTALL_DIR/scenarios/break_sso.sh"
            ;;
        5)
            lab_name="BRIDGE"     # -> scenarios/break_bridge.sh, tests/test_bridge.sh
            break_script="$INSTALL_DIR/scenarios/break_bridge.sh"
            ;;
        6)
            lab_name="AUTHCONFIG" # -> scenarios/break_authconfig.sh, tests/test_authconfig.sh
            break_script="$INSTALL_DIR/scenarios/break_authconfig.sh"
            ;;
        7)
            lab_name="PROXYFAIL"  # -> scenarios/break_proxyfail.sh, tests/test_proxyfail.sh
            break_script="$INSTALL_DIR/scenarios/break_proxyfail.sh"
            ;;
        *)
            echo -e "${RED}Invalid lab selection${NC}"
            return 1
            ;;
    esac

    show_banner
    echo -e "${YELLOW}Starting Lab: $lab_name${NC}"
    echo ""

    read -p "This will break your Docker Desktop environment. Continue? (y/N): " confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        echo "Cancelled."
        return 0
    fi

    echo ""
    echo "Breaking Docker Desktop..."

    if ! bash "$break_script"; then
        echo -e "${RED}Failed to break the environment. Is Docker Desktop running?${NC}"
        return 1
    fi

    # Record that the lab is active
    set_current_scenario "$lab_name"
    set_scenario_start_time "$(date +%s)"

    show_banner
    echo -e "${GREEN}Lab Started: $lab_name${NC}"
    echo ""
    echo -e "${BLUE}=========================================="
    echo "Your Mission"
    echo -e "==========================================${NC}"
    show_lab_instructions "$lab_name"
    echo ""
    echo -e "${BLUE}=========================================="
    echo "When You're Done"
    echo -e "==========================================${NC}"
    echo ""
    echo "When you think you've fixed the issue, run:"
    echo -e "${GREEN}  troubleshootlinuxlab --check${NC}"
    echo ""
    echo "This will test your fix and provide a score."
    echo ""
    echo "To see these instructions again, run:"
    echo "  troubleshootlinuxlab --help"
    echo ""
    echo "Good luck!"
    echo ""
}

# ------------------------------------------------------------------
# check_lab - Run the test script and record a grade
#
# The test script is run in a subshell and all its stdout is captured
# to a temp file. check_lab then:
#   1. Parses the structured footer lines (Score/Tests Passed/Tests Failed)
#   2. Displays the full test output to the trainee
#   3. Copies the output to REPORTS_DIR as a permanent record
#   4. Appends a grade row to grades.csv via record_grade
#   5. Clears the active scenario from config.json
#   6. Asks whether the trainee wants to try another lab
#      - Yes: returns normally so main()'s while loop redraws the menu
#      - No:  exits the process
# ------------------------------------------------------------------
check_lab() {
    local current_scenario
    current_scenario=$(get_current_scenario)

    if [ -z "$current_scenario" ] || [ "$current_scenario" = "null" ]; then
        echo -e "${RED}No active lab. Start a lab first.${NC}"
        exit 1
    fi

    show_banner
    echo -e "${YELLOW}Testing your fix for: $current_scenario${NC}"
    echo ""
    echo "Running diagnostic tests..."
    echo ""

    # Convert scenario name to lowercase for the filename (bash 3+ compatible)
    local scenario_lower
    scenario_lower=$(echo "$current_scenario" | tr '[:upper:]' '[:lower:]')
    local test_script="$INSTALL_DIR/tests/test_${scenario_lower}.sh"

    # Capture all test output to a temp file so we can both display it and
    # parse the structured footer lines without running the script twice.
    local test_output
    test_output=$(mktemp)

    if ! bash "$test_script" > "$test_output" 2>&1; then
        echo -e "${RED}Test script encountered an error${NC}"
        cat "$test_output"
        rm -f "$test_output"
        exit 1
    fi

    # Parse structured output written by the test script. Each test script must
    # write these three lines to stdout (see footer of each tests/test_*.sh):
    #   Score: <n>%
    #   Tests Passed: <n>
    #   Tests Failed: <n>
    # The ^ anchor ensures we only match lines that start with the field name,
    # preventing false matches from other output that contains these substrings.
    # Defaults to 0 for any field that is missing or unparseable.
    local score
    score=$(grep "^Score:" "$test_output" | grep -o '[0-9]\+' | head -1)
    score=${score:-0}

    local tests_passed
    tests_passed=$(grep "^Tests Passed:" "$test_output" | grep -o '[0-9]\+')
    tests_passed=${tests_passed:-0}

    local tests_failed
    tests_failed=$(grep "^Tests Failed:" "$test_output" | grep -o '[0-9]\+')
    tests_failed=${tests_failed:-0}

    # Calculate elapsed time
    local start_time end_time duration duration_min
    start_time=$(get_scenario_start_time)
    end_time=$(date +%s)
    duration=$((end_time - start_time))
    duration_min=$((duration / 60))

    # Display full test output
    show_banner
    echo -e "${BLUE}=========================================="
    echo "Lab Results: $current_scenario"
    echo -e "==========================================${NC}"
    echo ""
    cat "$test_output"
    echo ""

    # Persist the full output as a report file
    local report_file="$REPORTS_DIR/${current_scenario}_$(date +%Y%m%d_%H%M%S).txt"
    cp "$test_output" "$report_file"

    # Record the grade in the CSV
    record_grade "$USER" "$current_scenario" "$score" "$duration"

    # Personalised feedback section
    echo -e "${BLUE}=========================================="
    echo "Feedback"
    echo -e "==========================================${NC}"
    echo ""
    echo "Time taken:   $duration_min minutes"
    echo "Tests passed: $tests_passed"
    echo "Tests failed: $tests_failed"
    echo ""

    if [ "$score" -ge 90 ]; then
        echo -e "${GREEN}Excellent work!${NC}"
        echo "You demonstrated strong troubleshooting skills."
        echo "You're ready for production support on this topic."
    elif [ "$score" -ge 80 ]; then
        echo -e "${GREEN}Good job!${NC}"
        echo "You fixed the main issues. Review the failed tests to go further."
    elif [ "$score" -ge 70 ]; then
        echo -e "${YELLOW}Passing${NC}"
        echo "You got the basics but missed some key points."
        echo "Consider retrying this lab for better mastery."
    else
        echo -e "${RED}Needs improvement${NC}"
        echo "The issue was not fully resolved."
        echo "Review the diagnostic steps and try again."
    fi

    echo ""
    echo "Full report saved to:"
    echo "  $report_file"
    echo ""

    # Clear active lab state so a new one can be started
    clear_current_scenario

    # Clean up temp file before the prompt - the prompt may exit the process
    # or return to the caller's loop, both of which are fine.
    rm -f "$test_output"

    # Offer to continue. "Yes" returns to the caller so the interactive menu
    # loop in main() redraws naturally - no recursion needed. "No" exits.
    echo -e "${BLUE}==========================================${NC}"
    echo ""
    read -p "Would you like to try another lab? (y/N): " continue_training
    if [ "$continue_training" != "y" ] && [ "$continue_training" != "Y" ]; then
        echo ""
        echo "Training session complete."
        echo ""
        echo "To review your overall progress, run:"
        echo "  troubleshootlinuxlab --report"
        echo ""
        exit 0
    fi
}

# ------------------------------------------------------------------
# show_help
# ------------------------------------------------------------------
show_help() {
    show_banner
    cat << 'EOF'
Usage: troubleshootlinuxlab [OPTION]

Interactive Docker Desktop troubleshooting training labs for Linux.

With no options, launches the interactive lab selection menu.

Options:
  --check          Test and grade your current lab solution
  --report         Show your training report card
  --status         Show currently active lab
  --abandon        Abandon current lab without scoring
  --reset          Re-break the current lab so you can try again
  --help           Show this help message

Examples:
  troubleshootlinuxlab              # Start interactive menu
  troubleshootlinuxlab --check      # Submit current lab for grading
  troubleshootlinuxlab --report     # View your progress
  troubleshootlinuxlab --reset      # Reset current lab (timer restarts)

Lab Workflow:
  1. Run 'troubleshootlinuxlab' and select a lab
  2. The lab breaks Docker Desktop in a specific way
  3. Use your troubleshooting skills to diagnose and fix
  4. Run 'troubleshootlinuxlab --check' when done
  5. Review your score and feedback

Current active lab (if any):
EOF
    local current
    current=$(get_current_scenario)
    if [ -n "$current" ] && [ "$current" != "null" ]; then
        local start_time now elapsed
        start_time=$(get_scenario_start_time)
        now=$(date +%s)
        elapsed=$(( (now - start_time) / 60 ))
        echo "  $current (started $elapsed minutes ago)"
    else
        echo "  None"
    fi
    echo ""
    echo "For more information, visit:"
    echo "  https://docs.docker.com"
    echo ""
}

# ------------------------------------------------------------------
# show_status
# ------------------------------------------------------------------
show_status() {
    show_banner
    local current
    current=$(get_current_scenario)

    if [ -z "$current" ] || [ "$current" = "null" ]; then
        echo "No active lab."
        echo ""
        echo "Start a lab with:"
        echo "  troubleshootlinuxlab"
        echo ""
    else
        echo -e "${YELLOW}Active Lab: $current${NC}"
        echo ""
        local start_time now elapsed
        start_time=$(get_scenario_start_time)
        now=$(date +%s)
        elapsed=$(( (now - start_time) / 60 ))
        echo "Time elapsed: $elapsed minutes"
        echo ""
        echo "When done, run:"
        echo -e "  ${GREEN}troubleshootlinuxlab --check${NC}"
        echo ""
        echo "To see instructions again:"
        echo "  troubleshootlinuxlab --help"
        echo ""
    fi
}

# ------------------------------------------------------------------
# show_report_card
#
# Displays the last recorded score for each scenario. If a trainee
# completed the same lab more than once, only their most recent
# attempt is shown, but the overall average reflects those last scores
# only (one entry per scenario). This matches the Mac implementation.
# ------------------------------------------------------------------
show_report_card() {
    show_banner
    echo -e "${BLUE}=========================================="
    echo "Your Training Report Card"
    echo -e "==========================================${NC}"
    echo ""

    if [ ! -f "$GRADES_FILE" ] || [ "$(wc -l < "$GRADES_FILE")" -le 1 ]; then
        echo "No labs completed yet."
        echo ""
        echo "Start your first lab with:"
        echo "  troubleshootlinuxlab"
        echo ""
        return
    fi

    local dns_score=""
    local port_score=""
    local proxy_score=""
    local sso_score=""
    local bridge_score=""
    local authconfig_score=""
    local proxyfail_score=""

    # Each scenario variable is overwritten on every matching row, so if a
    # trainee attempted the same lab multiple times only the last score is
    # shown. The average is computed from these same last-score-per-scenario
    # values after the loop so it stays consistent with what is displayed.
    while IFS=',' read -r trainee scenario score timestamp duration; do
        # Skip header row and rows belonging to other trainees
        if [ "$trainee" = "trainee_id" ] || [ "$trainee" != "$USER" ]; then
            continue
        fi

        case "$scenario" in
            DNS)        dns_score="${score}%"        ;;
            PORT)       port_score="${score}%"       ;;
            PROXY)      proxy_score="${score}%"      ;;
            SSO)        sso_score="${score}%"        ;;
            BRIDGE)     bridge_score="${score}%"     ;;
            AUTHCONFIG) authconfig_score="${score}%" ;;
            PROXYFAIL)  proxyfail_score="${score}%"  ;;
        esac
    done < "$GRADES_FILE"

    echo "Lab Scores:"
    echo "  DNS Resolution:      ${dns_score:-Not attempted}"
    echo "  Port Problems:       ${port_score:-Not attempted}"
    echo "  Pull Problems:       ${proxy_score:-Not attempted}"
    echo "  Login Problems:      ${sso_score:-Not attempted}"
    echo "  Broken Networking:   ${bridge_score:-Not attempted}"
    echo "  Auth Config Errors:  ${authconfig_score:-Not attempted}"
    echo "  Proxy Conn Issues:   ${proxyfail_score:-Not attempted}"
    echo ""

    # Sum the last score for each attempted scenario. ${s%\%} strips the
    # trailing '%' that was appended in the case statement above.
    local total_score=0
    local lab_count=0
    local s
    for s in "$dns_score" "$port_score" "$proxy_score" "$sso_score" \
              "$bridge_score" "$authconfig_score" "$proxyfail_score"; do
        [ -n "$s" ] || continue
        total_score=$((total_score + ${s%\%}))
        lab_count=$((lab_count + 1))
    done

    if [ "$lab_count" -gt 0 ]; then
        local avg_score
        avg_score=$((total_score / lab_count))
        echo "Overall Average: $avg_score%"
        echo ""

        if [ "$avg_score" -ge 90 ]; then
            echo -e "Grade: ${GREEN}A - Excellent!${NC}"
            echo "You're ready for production Docker Desktop support."
        elif [ "$avg_score" -ge 80 ]; then
            echo -e "Grade: ${GREEN}B - Good work!${NC}"
            echo "Strong troubleshooting skills. Minor review recommended."
        elif [ "$avg_score" -ge 70 ]; then
            echo -e "Grade: ${YELLOW}C - Passing${NC}"
            echo "Consider retaking labs with low scores for improvement."
        else
            echo -e "Grade: ${RED}F - Needs improvement${NC}"
            echo "Please review the training materials and try again."
        fi
    fi

    echo ""
    echo "Completed labs: $lab_count"
    echo ""
    echo -e "${BLUE}==========================================${NC}"
    echo ""
}

# abandon_lab
abandon_lab() {
    local current
    current=$(get_current_scenario)

    if [ -z "$current" ] || [ "$current" = "null" ]; then
        echo "No active lab to abandon."
        return
    fi

    echo -e "${YELLOW}Abandoning lab: $current${NC}"
    read -p "Are you sure? This will not be scored. (y/N): " confirm

    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        clear_current_scenario
        echo "Lab abandoned."
        echo ""
        echo "Restoring Docker Desktop environment..."
        echo "(This may take up to 60 seconds if Docker Desktop needs to restart)"
        echo ""
        # Source the fix library and call only the fix for this lab.
        # Running all.sh (which fixes all 7 scenarios) was previously used
        # here, but it was run in the background with output suppressed.
        # For bridge (and any lab that requires a Docker restart), that made
        # the restore appear to fail because the trainee could test before
        # all.sh had finished its restart cycle. Running synchronously here
        # means the trainee gets their terminal back only once the environment
        # is genuinely restored.
        local current_lower fix_func
        current_lower=$(echo "$current" | tr '[:upper:]' '[:lower:]')
        # Map scenario name to the fix_* function in lib/fix.sh
        case "$current" in
            PORT)       fix_func="fix_ports"      ;;
            PROXY)      fix_func="fix_proxy"      ;;
            PROXYFAIL)  fix_func="fix_proxyfail"  ;;
            SSO)        fix_func="fix_sso"        ;;
            BRIDGE)     fix_func="fix_bridge"     ;;
            AUTHCONFIG) fix_func="fix_authconfig" ;;
            DNS)        fix_func="fix_dns"        ;;
            *)          fix_func=""              ;;
        esac

        if [ -n "$fix_func" ]; then
            # Source fix.sh so its functions are available in this shell
            # shellcheck disable=SC1091
            source "$INSTALL_DIR/lib/fix.sh"
            # PROXY, PROXYFAIL, SSO, and AUTHCONFIG write to settings files
            # that Docker would overwrite on a clean shutdown if Docker were
            # running when the fix writes them. Stop Docker first for those.
            case "$current" in
                PROXY|PROXYFAIL|SSO|AUTHCONFIG)
                    stop_docker_desktop
                    ;;
            esac
            # Tee output to a log file so it survives the menu screen-clear.
            local log_file="$STATE_DIR/fix.log"
            $fix_func 2>&1 | tee "$log_file"
            local fix_exit=${PIPESTATUS[0]}
            echo "" | tee -a "$log_file"
            echo "Full output saved to: $log_file" | tee -a "$log_file"
            # PROXY/PROXYFAIL/SSO/AUTHCONFIG: restart Docker Desktop now that
            # the settings file edits are in place.
            case "$current" in
                PROXY|PROXYFAIL|SSO|AUTHCONFIG)
                    echo ""
                    echo "Restarting Docker Desktop with corrected settings..."
                    systemctl --user start docker-desktop 2>/dev/null || true
                    local i
                    for i in $(seq 1 60); do
                        if docker info > /dev/null 2>&1; then
                            echo "  Docker Desktop ready"
                            break
                        fi
                        sleep 2
                    done
                    ;;
            esac
        else
            # Unknown scenario — fall back to full restore via all.sh
            echo "y" | bash "$INSTALL_DIR/scenarios/all.sh"
        fi

        echo ""
        echo "Environment restored. You can now start a new lab."
    else
        echo "Cancelled."
    fi
}

# ------------------------------------------------------------------
# reset_lab - Re-run the break script so the trainee can try again
# ------------------------------------------------------------------
reset_lab() {
    local current
    current=$(get_current_scenario)

    if [ -z "$current" ] || [ "$current" = "null" ]; then
        echo "No active lab to reset."
        return
    fi

    echo -e "${YELLOW}Resetting lab: $current${NC}"
    echo "This will re-break the environment so you can try again."
    read -p "Continue? (y/N): " confirm

    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        local current_lower
        current_lower=$(echo "$current" | tr '[:upper:]' '[:lower:]')
        bash "$INSTALL_DIR/scenarios/break_${current_lower}.sh"

        # Restart the timer
        set_scenario_start_time "$(date +%s)"
        echo -e "${GREEN}Lab reset. Timer restarted. Good luck!${NC}"
    else
        echo "Cancelled."
    fi
}

# ------------------------------------------------------------------
# main
#
# The menu has two distinct states:
#   Active lab:   options to continue, submit, abandon, or view report
#   No active lab: options to start a lab or view report
# get_current_scenario is called once per loop iteration rather than
# once at startup so it picks up state changes made by check_lab and
# abandon_lab.
# ------------------------------------------------------------------
main() {
    case "${1:-}" in
        --check|--submit)
            # After check_lab returns (user chose to try another lab),
            # fall through to the interactive menu loop below.
            check_lab
            ;;
        --help|-h)
            show_help
            exit 0
            ;;
        --status)
            show_status
            exit 0
            ;;
        --report|--grades)
            show_report_card
            exit 0
            ;;
        --abandon)
            abandon_lab
            exit 0
            ;;
        --reset)
            reset_lab
            exit 0
            ;;
        "")
            # Fall through to the interactive menu loop
            ;;
        *)
            echo "Unknown option: $1"
            echo "Run 'troubleshootlinuxlab --help' for usage information."
            exit 1
            ;;
    esac

    # Interactive menu loop
    while true; do
        show_main_menu
        read -p "Select option: " choice

        local current
        current=$(get_current_scenario)

        if [ -n "$current" ] && [ "$current" != "null" ]; then
            # Active lab menu
            case $choice in
                1)
                    echo ""
                    echo "Continue working on your lab."
                    echo "Run 'troubleshootlinuxlab --check' when done."
                    echo ""
                    read -p "Press enter to continue..."
                    exit 0
                    ;;
                2)
                    check_lab
                    ;;
                3)
                    abandon_lab
                    read -p "Press enter to continue..."
                    ;;
                4)
                    show_report_card
                    read -p "Press enter to continue..."
                    ;;
                0)
                    echo "Goodbye!"
                    exit 0
                    ;;
                *)
                    echo "Invalid option"
                    sleep 1
                    ;;
            esac
        else
            # No active lab menu
            case $choice in
                [1-7])
                    start_lab $choice
                    exit 0
                    ;;
                8)
                    show_report_card
                    read -p "Press enter to continue..."
                    ;;
                0)
                    echo "Goodbye!"
                    exit 0
                    ;;
                *)
                    echo "Invalid option"
                    sleep 1
                    ;;
            esac
        fi
    done
}

main "$@"
