#!/bin/bash
# troubleshootmaclab - Main training lab CLI
#
# Architecture overview
# ---------------------
# This script is the single entry point trainees interact with. Everything
# else is support infrastructure:
#
#   lib/colors.sh    - Color variables (RED, GREEN, YELLOW, BLUE, NC)
#   lib/state.sh     - Read/write ~/.docker-training-labs/config.json
#   lib/grading.sh   - Append rows to ~/.docker-training-labs/grades.csv
#
#   scenarios/break_<n>.sh  - Deliberately corrupt Docker Desktop
#   tests/test_<n>.sh       - Verify the scenario has been fixed
#   fixes/fix_<n>.sh        - Dev-only restore scripts (not for trainees)
#
# Lab lifecycle
# -------------
#   1. Trainee selects a lab from the menu (or passes a number to start_lab)
#   2. start_lab runs scenarios/break_<n>.sh and records the scenario
#      name and start timestamp in config.json via lib/state.sh
#   3. Trainee diagnoses and fixes Docker Desktop manually
#   4. --check runs tests/test_<n>.sh, captures its stdout, parses the
#      structured footer, records the grade, and prints feedback
#   5. config.json is cleared so a new lab can be started
#
# Output contract (tests/test_*.sh footer, parsed by check_lab)
# -------------------------------------------------------------
#   Score: <n>%
#   Tests Passed: <n>    <- written by generate_report in test_framework.sh
#   Tests Failed: <n>    <- written by generate_report in test_framework.sh
#
# Scenario name convention
# ------------------------
#   Lab names (DNS, PORT, BRIDGE, PROXY, CHAOS) are stored verbatim in
#   config.json and lowercased at runtime to derive filenames:
#     break_dns.sh / test_dns.sh, break_ports.sh / test_port.sh, etc.

# set -e is intentionally omitted. This is an interactive script with a menu
# loop and functions that legitimately return non-zero (e.g. user cancels a
# prompt). Errors are handled explicitly at each call site instead.

# Configuration
INSTALL_DIR="/usr/local/lib/docker-training-labs"
STATE_DIR="$HOME/.docker-training-labs"
CONFIG_FILE="$STATE_DIR/config.json"
GRADES_FILE="$STATE_DIR/grades.csv"
REPORTS_DIR="$STATE_DIR/reports"

# Ensure state directories exist (in case install was interrupted)
mkdir -p "$STATE_DIR" "$REPORTS_DIR" 2>/dev/null || true

# Initialize config file if missing
if [ ! -f "$CONFIG_FILE" ]; then
    cat > "$CONFIG_FILE" << EOF
{
  "version": "1.0.0",
  "trainee_id": "$USER",
  "current_scenario": null,
  "scenario_start_time": null
}
EOF
fi

# Initialize grades file if missing
if [ ! -f "$GRADES_FILE" ]; then
    cat > "$GRADES_FILE" << EOF
trainee_id,scenario,score,timestamp,duration_seconds
EOF
fi

# Source library functions
source "$INSTALL_DIR/lib/colors.sh"
source "$INSTALL_DIR/lib/state.sh"
source "$INSTALL_DIR/lib/grading.sh"

# Show banner
show_banner() {
    clear
    echo -e "${BLUE}=========================================="
    echo "Docker Desktop Training Labs"
    echo "Break-Fix Troubleshooting Practice"
    echo -e "==========================================${NC}"
    echo ""
}

# Show main menu
show_main_menu() {
    show_banner
    
    local current_scenario=$(get_current_scenario)
    
    if [ -n "$current_scenario" ] && [ "$current_scenario" != "null" ]; then
        echo -e "${YELLOW}WARNING: You currently have an active lab: $current_scenario${NC}"
        echo ""
        echo "1. Continue working on current lab"
        echo "2. Submit current lab for grading"
        echo "3. Abandon current lab and start new"
        echo "4. View my report card"
        echo "0. Exit"
    else
        echo "Select a training lab:"
        echo ""
        echo "1. Container Connections"
        echo ""
        echo "2. Port Problems"
        echo ""
        echo "3. Broken Networking"
        echo ""
        echo "4. Pull Problems"
        echo ""
        echo "5. CHAOS MODE - All labs at once!"
        echo ""
        echo "6. View my report card"
        echo "0. Exit"
    fi
    
    echo ""
    echo -e "${BLUE}==========================================${NC}"
}

# start_lab - Run a break scenario and record it as the active lab
#
# lab_name is the canonical scenario identifier. It is stored in config.json
# and lowercased at runtime to derive both the break script and test script
# filenames. Adding a new lab requires: a break_<lower>.sh, a test_<lower>.sh,
# a new case here, and a menu entry in show_main_menu.
start_lab() {
    local lab_number=$1
    local lab_name=""
    local break_script=""
    
    case $lab_number in
        1)
            lab_name="DNS"        # -> scenarios/break_dns.sh, tests/test_dns.sh
            break_script="$INSTALL_DIR/scenarios/break_dns.sh"
            ;;
        2)
            lab_name="PORT"       # -> scenarios/break_ports.sh, tests/test_port.sh
            break_script="$INSTALL_DIR/scenarios/break_ports.sh"
            ;;
        3)
            lab_name="BRIDGE"     # -> scenarios/break_bridge.sh, tests/test_bridge.sh
            break_script="$INSTALL_DIR/scenarios/break_bridge.sh"
            ;;
        4)
            lab_name="PROXY"      # -> scenarios/break_proxy.sh, tests/test_proxy.sh
            break_script="$INSTALL_DIR/scenarios/break_proxy.sh"
            ;;
        5)
            lab_name="CHAOS"      # -> scenarios/break_all.sh, tests/test_chaos.sh
            break_script="$INSTALL_DIR/scenarios/break_all.sh"
            ;;
        *)
            echo -e "${RED}Invalid lab selection${NC}"
            return 1
            ;;
    esac
    
    show_banner
    echo -e "${YELLOW}Starting Lab: $lab_name${NC}"
    echo ""
    
    # Confirm they want to start
    read -p "This will break your Docker Desktop environment. Continue? (y/N): " confirm
    if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
        echo "Cancelled."
        return 0
    fi
    
    echo ""
    echo "Breaking Docker Desktop..."
    
    # Run the break script
    if ! bash "$break_script"; then
        echo -e "${RED}Failed to break the environment. Please check Docker Desktop status.${NC}"
        return 1
    fi
    
    # Record the start
    set_current_scenario "$lab_name"
    set_scenario_start_time "$(date +%s)"
    
    show_banner
    echo -e "${GREEN}Lab Started: $lab_name${NC}"
    echo ""
    echo -e "${BLUE}=========================================="
    echo "Your Mission"
    echo -e "==========================================${NC}"
    show_lab_instructions "$lab_name"
    echo ""
    echo -e "${BLUE}=========================================="
    echo "When You're Done"
    echo -e "==========================================${NC}"
    echo ""
    echo "When you think you've fixed the issue, run:"
    echo -e "${GREEN}  troubleshootmaclab --check${NC}"
    echo ""
    echo "This will test your fix and provide a score."
    echo ""
    echo "To see these instructions again, run:"
    echo "  troubleshootmaclab --help"
    echo ""
    echo "Good luck!"
    echo ""
}

# Show lab-specific instructions
show_lab_instructions() {
    local lab=$1
    
    case $lab in
        DNS)
            cat << 'EOF'
Problem: docker pull fails with a DNS write error

The Docker daemon cannot resolve external hostnames. Image pulls
fail immediately with an error like:

  write udp ...: write: operation not permitted

Your Mac's DNS works fine. Interestingly, nslookup inside a
container may also appear to work. The daemon and containers
use different DNS paths - that discrepancy is your first clue.

Symptoms you should observe:
- docker pull fails with "write: operation not permitted"
- Error references a DNS lookup on an internal IP (e.g. 192.168.65.x)
- Host machine DNS works fine
- docker run --rm alpine:latest nslookup google.com may succeed

Diagnostic Commands to Try:
- docker pull hello-world
- docker info | grep -i dns
- cat ~/.docker/daemon.json
- docker run --rm alpine:latest nslookup google.com

If config looks clean, think about what sits between the daemon
and the network. Check whether traffic is being blocked at a
lower level inside the Docker VM:

  docker run --rm --privileged --pid=host alpine:latest \
    nsenter -t 1 -m -u -n -i sh -c 'iptables -L OUTPUT -n -v'

Restarting Docker Desktop will clear the problem as a last
resort, but try to find and remove the root cause first.
EOF
            ;;
        PORT)
            cat << 'EOF'
Problem: Containers fail to bind to common ports

When you try to start containers that need standard ports
(80, 443, 3306, 5432, 8080), you get "address already in use"
errors.

Symptoms you should observe:
- docker run -p 80:80 nginx:alpine fails with port allocation error
- Multiple ports are mysteriously occupied
- Some blocking containers may be hard to find

Diagnostic Commands to Try:
- docker ps -a
- lsof -nP -iTCP:80 | grep LISTEN
- docker ps -a --filter "name=."
- netstat -an | grep LISTEN

Fix it by identifying and removing port conflicts!
EOF
            ;;
        BRIDGE)
            cat << 'EOF'
Problem: Container networking is broken

Your containers start successfully but have no network
connectivity. They can't reach the internet or each other,
even though they appear to have IP addresses.

Symptoms you should observe:
- Containers can't ping external IPs
- Containers can't communicate with each other
- Docker daemon is running normally
- Network appears to exist but doesn't work

Diagnostic Commands to Try:
- docker network ls
- docker network inspect bridge
- docker run --rm alpine:latest ping -c 3 8.8.8.8
- docker run --rm alpine:latest ip route

Advanced Diagnostics:
- Check iptables rules in the Docker VM
- Look for network subnet conflicts

Fix it by restoring proper network functionality!
EOF
            ;;
        PROXY)
            cat << 'EOF'
Problem: Docker cannot reach external registries

Your Docker Desktop cannot pull images or access external
resources. This is due to proxy misconfiguration.

Symptoms you should observe:
- docker pull fails with a proxy connection error
- Containers can't reach the internet
- Host machine internet access works fine

On Mac, Docker Desktop manages proxy settings independently of
~/.docker/daemon.json. The canonical location to check is:

  ~/Library/Group Containers/group.com.docker/settings-store.json

There is also a shell layer: environment variables in your RC
file can conflict with or reinforce the daemon-level setting.

Diagnostic Commands to Try:
- docker pull hello-world
- docker info | grep -i proxy
- cat ~/Library/Group\ Containers/group.com.docker/settings-store.json
- env | grep -i proxy

Look for:
- ProxyHTTPMode set to "manual" with an unroutable proxy address
- HTTP_PROXY / HTTPS_PROXY set in your shell environment

Fix both layers to fully resolve the issue!
EOF
            ;;
        CHAOS)
            cat << 'EOF'
Problem: EVERYTHING IS BROKEN

Multiple systems have failed simultaneously. You'll need to
diagnose and fix multiple issues:
- DNS resolution
- Port conflicts
- Network connectivity
- Proxy configuration

This simulates a real disaster scenario where multiple things
go wrong at once. Prioritize wisely and fix systematically!

Symptoms: Too many to list. You'll know it when you see it.

Tip: Fix issues in order of dependency:
1. Network/Bridge issues (affects everything)
2. DNS issues (affects external connectivity)
3. Proxy issues (affects registries)
4. Port conflicts (affects services)

Good luck. You'll need it.
EOF
            ;;
    esac
}

# check_lab - Run the test script for the active scenario and record a grade
#
# The test script is run in a subshell and all its stdout is captured to a
# temp file. check_lab then:
#   1. Parses the structured footer lines (Score/Tests Passed/Tests Failed)
#   2. Displays the full test output to the trainee
#   3. Copies the output to REPORTS_DIR as a permanent record
#   4. Appends a grade row to grades.csv via record_grade
#   5. Clears the active scenario from config.json
#   6. Asks whether the trainee wants to try another lab
#      - Yes: returns normally so main()'s while loop redraws the menu
#      - No:  exits the process
check_lab() {
    local current_scenario=$(get_current_scenario)
    
    if [ -z "$current_scenario" ] || [ "$current_scenario" = "null" ]; then
        echo -e "${RED}No active lab. Start a lab first.${NC}"
        exit 1
    fi
    
    show_banner
    echo -e "${YELLOW}Testing your fix for: $current_scenario${NC}"
    echo ""
    echo "Running diagnostic tests..."
    echo ""
    
    # tr '[:upper:]' '[:lower:]' is used instead of ${var,,} for Bash 3 compatibility.
    # The lowercased name maps directly to the test script filename.
    local scenario_lower=$(echo "$current_scenario" | tr '[:upper:]' '[:lower:]')
    local test_script="$INSTALL_DIR/tests/test_${scenario_lower}.sh"
    # Capture all test output to a temp file so we can both display it and
    # parse the structured footer lines without running the script twice.
    local test_output=$(mktemp)

    if ! bash "$test_script" > "$test_output" 2>&1; then
        echo -e "${RED}Test script failed to run${NC}"
        cat "$test_output"
        rm -f "$test_output"
        exit 1
    fi
    
    # Parse structured output written by the test script. Each test script must
    # write these three lines to stdout (see footer of each tests/test_*.sh file):
    #   Score: <n>%
    #   Tests Passed: <n>
    #   Tests Failed: <n>
    # The ^ anchor ensures we only match lines that start with the field name,
    # preventing false matches from other output that contains these substrings.
    # Defaults to 0 for any field that is missing or unparseable.
    local score=$(grep "^Score:" "$test_output" | grep -o '[0-9]\+' | head -1)
    score=${score:-0}
    local tests_passed=$(grep "^Tests Passed:" "$test_output" | grep -o '[0-9]\+')
    tests_passed=${tests_passed:-0}
    local tests_failed=$(grep "^Tests Failed:" "$test_output" | grep -o '[0-9]\+')
    tests_failed=${tests_failed:-0}
    
    # Calculate duration
    local start_time=$(get_scenario_start_time)
    local end_time=$(date +%s)
    local duration=$((end_time - start_time))
    local duration_min=$((duration / 60))
    
    # Show results
    show_banner
    echo -e "${BLUE}=========================================="
    echo "Lab Results: $current_scenario"
    echo -e "==========================================${NC}"
    echo ""
    cat "$test_output"
    echo ""
    
    # Save the full report
    local report_file="$REPORTS_DIR/${current_scenario}_$(date +%Y%m%d_%H%M%S).txt"
    cat "$test_output" > "$report_file"
    
    # Record the grade
    record_grade "$USER" "$current_scenario" "$score" "$duration"
    
    # Show personalized feedback
    echo -e "${BLUE}=========================================="
    echo "Feedback"
    echo -e "==========================================${NC}"
    echo ""
    echo "Time taken: ${duration_min} minutes"
    echo "Tests passed: $tests_passed"
    echo "Tests failed: $tests_failed"
    echo ""
    
    if [ $score -ge 90 ]; then
        echo -e "${GREEN}Excellent work!${NC}"
        echo "You demonstrated strong troubleshooting skills."
        echo "You're ready for production support on this topic."
    elif [ $score -ge 80 ]; then
        echo -e "${GREEN}Good job!${NC}"
        echo "You fixed the main issues successfully."
        echo "Review the failed tests to improve further."
    elif [ $score -ge 70 ]; then
        echo -e "${YELLOW}Passing${NC}"
        echo "You got the basics, but missed some key points."
        echo "Consider trying this lab again for better mastery."
    else
        echo -e "${RED}Needs Improvement${NC}"
        echo "The issue wasn't fully resolved."
        echo "Review the diagnostic steps and try again."
    fi
    
    echo ""
    echo "Full report saved to:"
    echo "  $report_file"
    echo ""
    
    # Clear the current scenario
    clear_current_scenario

    # Clean up temp file now - before the prompt, since the prompt may exit
    # the process or return to the caller's loop, both of which are fine.
    rm -f "$test_output"

    # Offer to continue. "Yes" returns to the caller so the interactive menu
    # loop in main() redraws naturally - no recursion needed. "No" exits.
    echo -e "${BLUE}==========================================${NC}"
    echo ""
    read -p "Would you like to try another lab? (y/N): " continue_training
    if [ "$continue_training" != "y" ] && [ "$continue_training" != "Y" ]; then
        echo ""
        echo "Training session complete. Great work!"
        echo ""
        echo "To see your overall progress, run:"
        echo "  troubleshootmaclab --report"
        echo ""
        exit 0
    fi
}

